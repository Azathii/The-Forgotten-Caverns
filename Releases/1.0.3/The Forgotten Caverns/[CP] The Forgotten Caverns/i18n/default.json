  "Furniture_ForgottenCatalogue.Description": "A collection of furniture from a time long forgotten.",
  "Furniture_Terrarium.Description": "A collection of glowing Cavern plants. Provides a source of light.",
  "Furniture_ApothecaryDesk.Description": "An ancient wizard's desk used for all manner of potion creation.",
  "Furniture_GemDisplay.Description": "A pristine collection of gems and minerals.",
  "Furniture_WeaponDisplay.Description": "A replica of a rare, long-forgotten weapon.",
  "Furniture_WisteriaIndoor.Description": "A potted purple wisteria tree. Can be used indoors only.",
  "Furniture_WisteriaOutdoor.Description": "A purple wisteria tree which alters to an icy-blue hue during winter. Can be used outdoors only.",
  "Furniture_Houseplant.Description": "A flowering houseplant. 'Rotate' to change the plant pot design.",
  "Furniture_Bush.Description": "A flowering bush. 'Rotate' to change the plant pot design.",
  "Furniture_Mix.Description": "A collection of flowering plants. 'Rotate' to change the plant pot design.",
  "Furniture_Candelabra.Description": "Functions as a lamp; candles will light at sunset.",
  "Furniture_Scales.Description": "A set of scales with a blood-soaked history. Great for measuring both your brownie ingredients and your soul... or lack thereof.",
  "Furniture_Grimoire.Description": "An ancient grimoire, no doubt filled with the secrets of the mysterium... if only you could understand it.",
  "Furniture_Mirror.Description": "Mirror, mirror on the wall...",
  "Furniture_SelfPortrait.Description": "A cautionary painting of one crushed to death by the size of their own ego.",
  "Furniture_Bed.Description": "A bed from ages past.",
  "Furniture_Canopy.Description": "Can be placed in front of any 'Ancient' bed.",
  "Furniture_Urn.Description": "An ancient burial urn from a long-forgotten time.",
  "Furniture_GraveRoses.Description": "To be placed at the grave of a lost loved one.",
  "Furniture_Grave.Description": "Used to mark the burial plot of a loved one... or as a nifty Halloween decoration!",
  "Furniture_Sarcophagus.Description": "Perfect for creating your very own crypt, or for hiding dirty laundry when unexpected visitors arrive!",
  "Furniture_Bones.Description": "The freshly-unearthed remains of a poor forgotten soul.",
  "Furniture_Catacomb.Description": "Never again feel alone, with a haunted catacomb in your home!",
  "Furniture_Cauldron.Description": "An animated, bubbling cauldron. Provides a source of light.",
  "Furniture_FlickerCandle.Description": "An animated burning candle. Provides a source of light.",
  "Furniture_SpiritSconce.Description": "A flickering blue flame taken from an ancient crypt. Provides a source of light.",
  "Furniture_SpiritStatue.Description": "A large, demonic-looking statue holding a dancing blue spirit flame. Provides a source of light.",

//SHOPS
  "Shop_GraveRobber1": "Grave Robber: Shhhh! If Sid catches me he'll throw me to the pit-fiends... again! I've still got teeth marks in my tibia from the last time.",
  "Shop_GraveRobber2": "Grave Robber: I wonder why people insist on being buried with family recipes?",
  "Shop_GraveRobber3": "Grave Robber: Bone fragments are great for distracting pit fiends!",
  "Shop_PrizeKiosk1": "Prize Clerk: If you have coins that are royal in hue, fabulous prizes are waiting for you!",
  "Shop_PrizeKiosk2": "Prize Clerk: A much larger range of our furniture is available in our catalogue.",
  "RobinCottageRepair": "Repair Forgotten Cottage",

//QUESTS
  "Quest_CarlTitle": "Renovating Ruins",
  "Quest_CarlDescription": "You've paid Robin the funds to repair the Forgotten Cottage in the Caverns. Speak to Robin's friend tomorrow and deliver the blueprints.",
  "Quest_CarlInstructions": "Meet Carl at the Forgotten Cottage ruins tomorrow and give him Robin's blueprints.",
  "Quest_PetraTitle": "Perfection for Petra",
  "Quest_PetraDescription": "Petra believes in striving for perfection in life. Speak to her again once you begin to follow that ethos for yourself.",
  "Quest_PetraInstructions": "Speak to Petra in the Skeleton Speakeasy once you start tracking your perfection score.",
  "Quest_PetraRewardTitle": "Petra's Reward",
  "Quest_PetraRewardDescription": "Petra would like to reward you for tracking your perfection score.",
  "Quest_PetraRewardInstructions": "Head to the Speakeasy Vault and open Petra's chest.",
  "Quest_EarlTitle": "The Spice of Life?",
  "Quest_EarlDescription": "Earl is looking to add an extra 'kick' to his nightmarish concoction but has misplaced his spices.",
  "Quest_EarlInstructions": "Find Earl's spices somewhere nearby.",
  "Quest_EarlRewardTitle": "Earl's Reward",
  "Quest_EarlRewardDescription": "Earl is grateful you returned his lost spices.",
  "Quest_EarlRewardInstructions": "Head to the Speakeasy Vault and open Earl's chest.",
  "Quest_CaptainTitle": "Caring for a Captain",
  "Quest_CaptainDescription": "Thinking of the solemn skeletal Captain leaves your heart feeling heavy. See if you can trace his steps through the Catacombs and find something that may cheer him up.",
  "Quest_CaptainInstructions": "Find something that will cheer up the skeletal Pirate Captain.",
  "Quest_CaptainRewardTitle": "The Captain's Reward",
  "Quest_CaptainRewardDescription": "You've reunited The Captain with his lost memento.",
  "Quest_CaptainRewardInstructions": "Head to the Speakeasy Vault and open The Captain's chest.",
  "Quest_WrenTitle": "A Vexing Volcano",
  "Quest_WrenDescription": "Wren always dreamed of seeing the Volcano Caldera; maybe you can achieve that goal for them?",
  "Quest_WrenInstructions": "Speak to Wren in the Skeleton Speakeasy once you have visited the Ginger Island Volcano Caldera.",
  "Quest_WrenRewardTitle": "Wren's Reward",
  "Quest_WrenRewardDescription": "You've returned to Wren and told your tales of the Caldera.",
  "Quest_WrenRewardInstructions": "Head to the Speakeasy Vault and open Wren's chest.",
  "Quest_EdgarTitle": "Mightier Than the Sword",
  "Quest_EdgarDescription": "Edgar has mislaid his ink and quill somewhere in the Catacombs; without them he cannot write his posthumous poetry!",
  "Quest_EdgarInstructions": "Search the Catacombs for Edgar's missing Ink and Quill.",
  "Quest_EdgarRewardTitle": "Edgar's Reward",
  "Quest_EdgarRewardDescription": "Your successful sarcophagi search finally led to reuniting Edgar with his missing ink and quill!",
  "Quest_EdgarRewardInstructions": "Head to the Speakeasy Vault and open Edgar's chest.",
  "Quest_Clue1Title": "Caverns Hunt: Clue 1",
  "Quest_Clue1Description": "Solve Clue 1.",
  "Quest_Clue1Instrutions": "A master of rod and tackle, a lost-lord of scaly things, he leaves behind his writings and the knowledge that it brings.",
  "Quest_Clue2Title": "Caverns Hunt: Clue 2",
  "Quest_Clue2Description": "Solve Clue 2.",
  "Quest_Clue2Instrutions": "Different from my kinsfolk, yet still bathed in glowing light, I dance upon a secret with my wings of gossamer night.",  
  "Quest_Clue3Title": "Caverns Hunt: Clue 3",
  "Quest_Clue3Description": "Solve Clue 3.",
  "Quest_Clue3Instrutions": "The sorrowed-halls echo eons, where all journeys reach their end, yet clinging 'neath a lilypad you'll find a lifelong friend.",
  "Quest_Clue4Title": "Caverns Hunt: Clue 4",
  "Quest_Clue4Description": "Solve Clue 4.",
  "Quest_Clue4Instrutions": "An over-used trope; tried, tested and true! Behind nature's curtain, a surprise waits for you...",
  "Quest_Clue5Title": "Caverns Hunt: Clue 5",
  "Quest_Clue5Description": "Solve Clue 5.",
  "Quest_Clue5Instrutions": "In a long-abandoned mine, where employees toiled their last, lies a long-forgotten worker with a gift from ages past.",
  "Quest_Clue6Title": "Caverns Hunt: Clue 6",
  "Quest_Clue6Description": "Solve Clue 6.",
  "Quest_Clue6Instrutions": "An avatar of my maker, royal hue adorns my head. I gaze upon a fool's alcove; veiled secret of the dead.",
  "Quest_Clue7Title": "Caverns Hunt: Clue 7",
  "Quest_Clue7Description": "Solve Clue 7.",
  "Quest_Clue7Instrutions": "In an area that time forgot, the greatest battle did transpire! It's a tale of greedy pirates and of angry lizard fire. Their eggs, you see, were valued high, so the pirates hatched a scheme, forgetting that the dino's weren't as docile as they seem. Alas, the pirate's plot did fail, and all remains is ash and smoke, yet they left behind a shining prize; just give their bones a poke!",
  "Quest_Clue8Title": "Caverns Hunt: Clue 8",
  "Quest_Clue8Description": "Solve Clue 8.",
  "Quest_Clue8Instrutions": "Amongst my fallen brethren, where we once reached to greet covered skies, I lie beneath the age-tattered reeds, in my husk the youth survives.",
  "Quest_Clue9Title": "Caverns Hunt: Clue 9",
  "Quest_Clue9Description": "Solve Clue 9.",
  "Quest_Clue9Instrutions": "Follow the sacred symbol, walk the cleric's faithful path, where if thy mettle's judged pure and true, you'll be gifted heaven's wrath.",
  "Quest_Clue10Title": "Caverns Hunt: Clue 10",
  "Quest_Clue10Description": "Solve Clue 10.",
  "Quest_Clue10Instrutions": "A foolish pirate's pension waits, buried deep on an island shore. As his hide was fried by a dinosaur pride, he'll need his gold no more.",

