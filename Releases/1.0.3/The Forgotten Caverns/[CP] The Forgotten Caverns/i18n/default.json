//BUFFS
  "BuffCleric.name": "Cleric's Blessing",
  "BuffCleric.description": "Increases your weapon speed and critical chance for 15 minutes.",
  "BuffFountain.name": "Fountain's Fortune",
  "BuffFountain.description": "Increases your luck level by 1 for the duration of the day.",
  "BuffGatherer.name": "Wild Shrine's Blessing: Gatherer",
  "BuffGatherer.description": "Increases your foraging level by 1 for the duration of the day.",
  "BuffHunter.name": "Wild Shrine's Blessing: Hunter",
  "BuffHunter.description": "Increases your fishing level by 1 for the duration of the day.",
  "BuffSpirit.name": "Spirit's Embrace",
  "BuffSpirit.description": "Increases your defence and immunity by 2 for 10 minutes.",

//HATS AND WEAPONS
  "Hat_AncientWizardHat.name": "Ancient Wizard Hat",
  "Hat_AncientWizardHat.description": "A musty old hat popular with wizards a hundred years ago.",
  "Hat_ClericsHelmet.name": "Cleric's Helmet",
  "Hat_ClericsHelmet.description": "The helmet of a Divine Cleric of Yoba. It is an ancient relic from a long-forgotten holy war.",
  "Weapon_Thorn.name": "Thorn",
  "Weapon_Thorn.description": "A dagger-like thorn plucked from a subterranean bush.",
  "Weapon_RadiantRapier.name": "Yoba's Wrath",
  "Weapon_RadiantRapier.description": "A sacred rapier hidden long ago by a devout cleric. Includes a unique enchantment that causes all slain monsters to drop gold equal to 10% of their max HP.",
  "Weapon_CursedCutlass.name": "Cursed Cutlass",
  "Weapon_CursedCutlass.description": "An eerie cutlass gifted to you by an undead pirate captain. Includes a unique enchantment that has a 50% chance for slain monsters to drop gold equal to 10% of their max HP.",

//ITEMS
  "KeyObject_CottageBlueprints.name": "Cottage Renovation Blueprints",
  "KeyObject_CottageBlueprints.description": "Purchasing this item allows the Forgotten Cottage in the Caverns to be repaired. Give these blueprints to Carl at the cottage ruins. ",
  "KeyObject_CaptainsLocket.name": "Captain's Locket",
  "KeyObject_CaptainsLocket.description": "A sentimental golden locket.",
  "KeyObject_EarlsSpices.name": "Earl's Spices",
  "KeyObject_EarlsSpices.description": "Two jars of rather unpleasant-looking spices.",
  "KeyObject_EdgarsInk.name": "Edgar's Quill and Ink",
  "KeyObject_EdgarsInk.description": "An elegant quill in a small jar of ink.",  
  "Object_BlindCaveTetra.name": "Blind Cave Tetra",
  "Object_BlindCaveTetra.description": "A tiny, pearlescent fish that thrives in subterranean streams.",
  "Object_CavernKoi.name": "Cavern Koi",
  "Object_CavernKoi.description": "An ornamental carp found in underground rivers and ponds.",
  "Object_MidnightCavernKoi.name": "Midnight Cavern Koi",
  "Object_MidnightCavernKoi.description": "A mutation of the Cavern Koi, this shy fish is only found late at night.",
  "Object_ForgottenFangtooth.name": "Forgotten Fangtooth",
  "Object_ForgottenFangtooth.description": "A mutated freshwater Fangtooth that lives in the deepest parts of underground rivers. They are most active in the evenings and seem to enjoy gothic aesthetics. Delicious when fried, but sometimes bites back...",
  "Object_KeyLime.name": "Key Lime",
  "Object_KeyLime.description": "A small, deep green citrus fruit with a tangy taste and heady fragrance.",
  "Object_Lemon.name": "Meyer Lemon",
  "Object_Lemon.description": "A sharp and sour citrus fruit with a fresh, zesty aroma.",
  "Object_KeyLimeSapling.name": "Key Lime Sapling",
  "Object_KeyLimeSapling.description": "Takes 28 days to produce a mature Key Lime tree. Bears fruit in the fall. Only grows if the 8 surrounding \"tiles\" are empty.",
  "Object_LemonSapling.name": "Meyer Lemon Sapling",
  "Object_LemonSapling.description": "Takes 28 days to produce a mature Meyer Lemon tree. Bears fruit in the summer. Only grows if the 8 surrounding \"tiles\" are empty.",
  "Object_Duskberry.name": "Duskberry",
  "Object_Duskberry.description": "A sweet and sharp berry that glows like a twilight-touched sky.",
  "Object_CavernSpinach.name": "Cavern Spinach",
  "Object_CavernSpinach.description": "A versatile, leafy vegetable that grows exclusively in vast caves.",
  "Object_GloomBloom.name": "Gloom Bloom",
  "Object_GloomBloom.description": "Also known as 'Yoba's Sorrow', this large yet delicate flower is known only to bloom in areas steeped in sadness.",
  "Object_MidnightEntoloma.name": "Midnight Entoloma",
  "Object_MidnightEntoloma.description": "An edible member of the entolomataceae family, this mushroom has a striking steel-blue hue and a delicious rich taste once cooked.",
  "Object_CavernLunch.name": "Cavern Lunch",
  "Object_CavernLunch.description": "A hearty lunch consisting of wilted Cavern spinach, sautéed midnight entoloma and crispy potatoes.",
  "Object_FriedFangtooth.name": "Fried Fangtooth",
  "Object_FriedFangtooth.description": "Succulent, flaky fish in a light seasoned batter.",
  "Object_CreamedCavernSpinach.name": "Creamed Cavern Spinach",
  "Object_CreamedCavernSpinach.description": "A creamy, comforting dish made with fresh Cavern spinach.",
  "Object_Lemonade.name": "Lemonade",
