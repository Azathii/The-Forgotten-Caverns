      "ToArea": {
        "X": 15,
        "Y": 11,
        "Width": 1,
        "Height": 2
      },
      "Patchmode": "Overlay",
      "When": {
	"HasFlag: currentPlayer, hostPlayer |contains={{ModId}}/EarlStartQuest": true,
	"HasFlag: currentPlayer, hostPlayer |contains={{ModId}}/EarlsSpicesFound": false,
